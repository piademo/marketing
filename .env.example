# Bloqueo de pre-lanzamiento (middleware)
# - Cuando está activo, todas las páginas (excepto /locked y /unlock) redirigen a /locked
# - Para acceder como equipo, entra en /unlock y usa la clave para guardar una cookie
# - En localhost NO se aplica el bloqueo (para desarrollo).

SITE_LOCK_ENABLED=true
SITE_LOCK_KEY=pon-una-clave-larga-aqui

# Secreto para firmar el token de desbloqueo (RECOMENDADO).
# Usa un valor largo y aleatorio (>=32 caracteres). No reutilices la clave humana.
SITE_LOCK_SECRET=pon-un-secreto-largo-y-aleatorio-aqui

# Hosts donde SÍ se aplicará el bloqueo (por defecto: bookfast.es,www.bookfast.es)
# SITE_LOCK_HOSTS=bookfast.es,www.bookfast.es

# CORS: orígenes permitidos para /api/* (separados por coma)
# Por defecto: https://bookfast.es,https://www.bookfast.es
# En dev añade: http://localhost:3000
# ALLOWED_ORIGINS=https://bookfast.es,https://www.bookfast.es

# -----------------------------------------------------------------------------
# Billing (Stripe Checkout + Supabase provisioning) — TEST MODE
# -----------------------------------------------------------------------------

# Stripe (secret server-side)
STRIPE_SECRET_KEY=sk_test_...

# Stripe API version (opcional; por defecto 2026-01-28.clover)
STRIPE_API_VERSION=2026-01-28.clover

# Stripe webhook signing secret (para /api/stripe/webhook)
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs de suscripción (plan base)
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_YEARLY=price_...
STRIPE_PRICE_PROFESSIONAL_MONTHLY=price_...
STRIPE_PRICE_PROFESSIONAL_YEARLY=price_...
STRIPE_PRICE_SCALE_MONTHLY=price_...
STRIPE_PRICE_SCALE_YEARLY=price_...

# Add-ons (Prices en Stripe, recurrentes)
STRIPE_ADDON_PRICE_WHATSAPP_PACK=price_...
STRIPE_ADDON_PRICE_SMS=price_...
STRIPE_ADDON_PRICE_PAYMENTS=price_...
STRIPE_ADDON_PRICE_WHITE_LABEL=price_...
STRIPE_ADDON_PRICE_AI=price_...

# Ofertas (opcional)
STRIPE_COUPON_EARLY_ADOPTERS=coupon_or_id_...

# URL base pública del marketing (para success/cancel URLs)
NEXT_PUBLIC_MARKETING_URL=http://localhost:3000

# Supabase (del proyecto de la plataforma, server-side)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=service_role_...

