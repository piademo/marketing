# Bloqueo de pre-lanzamiento (middleware)
# - Cuando está activo, todas las páginas (excepto /locked y /unlock) redirigen a /locked
# - Para acceder como equipo, entra en /unlock y usa la clave para guardar una cookie
# - En localhost NO se aplica el bloqueo (para desarrollo).

SITE_LOCK_ENABLED=true
SITE_LOCK_KEY=pon-una-clave-larga-aqui

# Secreto para firmar el token de desbloqueo (RECOMENDADO).
# Usa un valor largo y aleatorio (>=32 caracteres). No reutilices la clave humana.
SITE_LOCK_SECRET=pon-un-secreto-largo-y-aleatorio-aqui

# Hosts donde SÍ se aplicará el bloqueo (por defecto: bookfast.es,www.bookfast.es)
# SITE_LOCK_HOSTS=bookfast.es,www.bookfast.es

